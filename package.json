{
  "name": "fictionops-launch-tools",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:public": "node scripts/require-public-site-url.mjs && next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "verify:routes": "node scripts/verify-launch-readiness.mjs",
    "verify:local-preview": "node scripts/verify-local-preview.mjs",
    "verify": "npm run lint && npm test && npm run build && npm audit --omit=dev",
    "verify:public": "node scripts/require-public-site-url.mjs && npm run verify"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
